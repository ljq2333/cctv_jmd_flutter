{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["~/.config/opencode/node_modules/superpowers"],
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "flutter *": "allow",
      "dart *": "allow",
      "git *": "allow",
      "*": "ask"
    }
  }
}
